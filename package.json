{
  "name": "idea-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "live-server . --port=8080",
    "dev:color": "pnpm --filter color-wizard dev",
    "dev:json": "pnpm --filter json-toolkit dev",
    "dev:regex": "pnpm --filter regex-visualizer dev",
    "dev:diff": "pnpm --filter diff-checker dev",
    "dev:css": "pnpm --filter css-effects-generator dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test"
  }
}
